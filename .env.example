# ===== Smart Circular Summarization & Management System =====
# Copy this file to backend/.env and adjust values.

# ---- Flask ----
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-jwt-secret

# ---- Database ----
# Dev default (no MySQL required): SQLite
#DATABASE_URL=sqlite:///circular_management.sqlite3
# Production / thesis target: MySQL 8.0 (uncomment & fill)
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/circular_management

# ---- Session / Auth ----
JWT_ACCESS_MINUTES=30          # FR-03: 30-minute inactive session expiry

# ---- File upload ----
MAX_UPLOAD_MB=20               # FR-09: reject files over 20MB
UPLOAD_FOLDER=uploads

# ---- AI models (local inference, NFR-08) ----
SPACY_MODEL=en_core_web_sm
BERT_MODEL=bert-base-uncased
BART_MODEL=facebook/bart-large-cnn
BART_FALLBACK_MODEL=sshleifer/distilbart-cnn-12-6
SBERT_MODEL=all-MiniLM-L6-v2
MODEL_CACHE_DIR=model_cache

# ---- CORS (frontend origin) ----
FRONTEND_ORIGIN=http://localhost:5173
